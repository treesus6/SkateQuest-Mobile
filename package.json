{
  "name": "skatequest",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "eas build --platform android --profile preview",
    "ios": "eas build --platform ios --profile preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "analyze:bundle": "npx expo-bundle-visualizer",
    "prepare": "husky install || true",
    "build:production": "eas build --platform all --profile production",
    "update:production": "eas update --branch production --message 'prod: release'"
  },
  "trustedDependencies": [
    "@sentry/cli"
  ],
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@rnmapbox/maps": "11.20.1",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.89.0",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "lucide-react-native": "^0.563.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-logs": "^5.5.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "sanitize-html": "^2.17.3",
    "vexo-analytics": "1.5.4",
    "yup": "^1.7.1",
    "zustand": "^5.0.11",
    "react-native-worklets": "0.8.1",
    "react-native-gesture-handler": "~2.28.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@types/sanitize-html": "^2.13.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.39.2",
    "eslint-config-expo": "^10.0.0",
    "husky": "^8.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "react-test-renderer": "19.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.1.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "@react-navigation/bottom-tabs",
        "@react-navigation/native",
        "@react-navigation/native-stack",
        "expo-splash-screen",
        "react-native-worklets"
      ]
    }
  }
}
