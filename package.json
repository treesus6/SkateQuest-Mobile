{
  "name": "skatequest",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "eas build --platform android --profile preview",
    "ios": "eas build --platform ios --profile preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "analyze:bundle": "npx expo-bundle-visualizer",
    "prepare": "husky install || true",
    "build:production": "eas build --platform all --profile production",
    "update:production": "eas update --branch production --message 'prod: release'"
  },
  "trustedDependencies": [
    "@sentry/cli"
  ],
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-community/slider": "5.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@rnmapbox/maps": "10.3.1",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.89.0",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~56.0.11",
    "expo-application": "~56.0.3",
    "expo-auth-session": "~56.0.14",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~56.0.18",
    "expo-camera": "~56.0.8",
    "expo-clipboard": "^56.0.3",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-haptics": "~56.0.3",
    "expo-image-manipulator": "~56.0.18",
    "expo-image-picker": "~56.0.17",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-location": "~56.0.17",
    "expo-notifications": "~56.0.17",
    "expo-router": "~56.2.10",
    "expo-splash-screen": "~56.0.6",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^0.563.0",
    "nativewind": "^4.2.3",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~3.0.1",
    "react-native-logs": "^5.5.0",
    "react-native-reanimated": "4.4.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.5",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.9.2",
    "sanitize-html": ">=2.17.3",
    "vexo-analytics": "1.5.7",
    "yup": "^1.7.1",
    "zustand": "^5.0.11",
    "react-native-qrcode-svg": "^6.3.15"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@expo/config-plugins": "~56.0.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "30.0.0",
    "@types/react": "~19.2.14",
    "@types/sanitize-html": "^2.13.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~56.0.4",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "lint-staged": "^17.0.8",
    "prettier": "^3.0.0",
    "react-test-renderer": "19.2.7",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3",
    "eslint-plugin-react-hooks": "^7.1.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "private": true,
  "overrides": {
    "@xmldom/xmldom": "0.8.13",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "shell-quote": ">=1.8.2",
    "fast-uri": ">=3.1.0"
  },
  "expo": {
    "install": {
      "exclude": [
        "@react-navigation/bottom-tabs",
        "@react-navigation/native",
        "@react-navigation/native-stack",
        "expo-splash-screen",
        "react-native-worklets"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "vexo-analytics",
          "expo-av",
          "expo-modules-jsi"
        ]
      }
    }
  },
  "engines": {
    "node": ">=20.19.4"
  }
}
